{
  "name": "diff-drift",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "seed:demo": "node scripts/seed-demo.mjs",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:e2e:web": "playwright test -c playwright.web.config.ts",
    "test:e2e:tauri": "npm run tauri -- build --debug --no-bundle --ci && playwright test -c playwright.tauri.config.ts",
    "test:verify": "npm run test:rust && npm run build && npm run test:e2e:web",
    "test:verify:native": "npm run test:e2e:tauri"
  },
  "dependencies": {
    "@fontsource/cascadia-code": "^5.2.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
