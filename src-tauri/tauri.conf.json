{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "drift-inspector",
  "version": "0.1.0",
  "identifier": "com.driftinspector.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Diff Drift",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
