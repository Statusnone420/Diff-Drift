# Normalize text in the repo and keep source files LF in every checkout.
* text=auto

.gitattributes text eol=lf
.gitignore text eol=lf
LICENSE text eol=lf
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.lock text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.rs text eol=lf
*.svg text eol=lf
*.toml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

*.icns binary
*.ico binary
*.png binary
*.woff binary
*.woff2 binary
